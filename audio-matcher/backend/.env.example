OPENROUTER_API_KEY=your_openrouter_api_key_here
DEFAULT_MODEL=openai/gpt-oss-120b:free
# Comma-separated folders to scan for real VST3 plugins (selectable in the UI).
# Typical Windows path: C:\Program Files\Common Files\VST3
# Typical macOS path: /Library/Audio/Plug-Ins/VST3
# Typical Linux path: /usr/lib/vst3 or ~/.vst3
PLUGIN_SCAN_PATHS=/usr/lib/vst3,/home/user/.vst3
