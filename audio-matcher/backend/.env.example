OPENROUTER_API_KEY=your_openrouter_api_key_here
DEFAULT_MODEL=openai/gpt-oss-120b:free
# Comma-separated folders to scan for real VST3 (.vst3) and VST2 (.dll on
# Windows) plugins, selectable in the UI. Add as many folders as you want,
# comma-separated -- e.g. both your VST3 and VST2 folders on Windows:
# PLUGIN_SCAN_PATHS=C:\Program Files\Common Files\VST3,C:\Program Files\Steinberg\VSTPlugins
#
# Typical VST3 paths: C:\Program Files\Common Files\VST3 (Windows),
#   /Library/Audio/Plug-Ins/VST3 (macOS), /usr/lib/vst3 or ~/.vst3 (Linux)
# Typical VST2 path: C:\Program Files\Steinberg\VSTPlugins (Windows)
PLUGIN_SCAN_PATHS=/usr/lib/vst3,/home/user/.vst3
